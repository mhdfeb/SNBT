# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_APP_BASE_URL: Canonical production URL for analytics and app links.
VITE_APP_BASE_URL="https://example.com"

# VITE_APP_VERSION: Release tag shown in analytics/event payloads.
VITE_APP_VERSION="2026.04.01"

# VITE_ANALYTICS_ID: Google Analytics Measurement ID (optional).
VITE_ANALYTICS_ID="G-XXXXXXXXXX"
